# Variables de entorno para SyMTickets CCTV

# Base de Datos PostgreSQL
DATABASE_HOST=localhost
DATABASE_PORT=5437
DATABASE_USER=postgres
DATABASE_PASSWORD=joselo1341
DATABASE_NAME=symtickets
DATABASE_SSLMODE=disable
DATABASE_URL=postgres://postgres:joselo1341@localhost:5437/symtickets?sslmode=disable

# JWT
JWT_SECRET=change-this-secret-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-this-refresh-secret
JWT_REFRESH_EXPIRES_IN=7d

# Server
SERVER_PORT=8080
SERVER_ENV=development
GIN_MODE=debug

# Redis/Valkey (opcional)
REDIS_HOST=localhost
REDIS_PORT=6387

# MinIO (almacenamiento)
MINIO_BASE_URL=http://localhost:9007
MINIO_ENDPOINT=localhost:9007
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=symtickets
MINIO_REGION=us-east-1
MINIO_USE_SSL=false

# Logging
LOG_LEVEL=debug
LOG_FORMAT=json
